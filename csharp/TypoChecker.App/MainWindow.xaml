<Window x:Class="TypoChecker.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文章補正ツール" Height="240" Width="460">
    <StackPanel Margin="14">
        <TextBlock Text="ローカルLLM文章補正ツール" FontWeight="Bold" FontSize="14"/>
        <TextBlock x:Name="LblModel" Margin="0,8,0,0"/>
        <TextBlock x:Name="LblConn" Text="接続状態: 確認中…" Margin="0,2,0,0"/>
        <TextBlock Text="Ctrl+Alt+B = ビジネス依頼文化 / Ctrl+Alt+T = タイポ修正"
                   Foreground="Gray" Margin="0,8,0,0" TextWrapping="Wrap"/>
        <TextBlock x:Name="LblStatus" Margin="0,8,0,0" TextWrapping="Wrap" MinHeight="36"/>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="接続確認" Click="OnCheckConn" Padding="12,4"/>
            <Button Content="終了" Click="OnQuit" Padding="12,4" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
