<Window x:Class="TypoChecker.WpfApp.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="補正結果" Height="520" Width="860">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblMode" FontWeight="Bold" FontSize="13"/>

        <Grid Grid.Row="1" Margin="0,8,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="原文" Grid.Column="0"/>
            <TextBlock Text="生成文（編集可）" Grid.Column="1"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSrc" Grid.Column="0" IsReadOnly="True"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" Background="#F4F4F4" Margin="0,0,5,0"/>
            <TextBox x:Name="TxtGen" Grid.Column="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" Margin="5,0,0,0"/>
        </Grid>

        <TextBlock x:Name="LblStatus" Grid.Row="3" Margin="0,6,0,0" Foreground="Gray"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="コピー（再コピー）" Click="OnCopy" Padding="12,4"/>
            <Button Content="採用 Y（意味一致）" Click="OnAcceptY" Padding="12,4" Margin="8,0,0,0"/>
            <Button Content="不採用 N" Click="OnAcceptN" Padding="12,4" Margin="8,0,0,0"/>
            <Button Content="閉じる" Click="OnClose" Padding="12,4" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
